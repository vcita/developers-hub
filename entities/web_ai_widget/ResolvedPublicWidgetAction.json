{
  "type": "object",
  "description": "Resolved action for public embed: merged portal + widget overrides (snake_case).",
  "properties": {
    "name": { "type": "string", "description": "Action key/name" },
    "action": { "type": "string", "description": "Action type/key" },
    "text": { "type": "string", "description": "Display label" },
    "uid": { "type": "string", "description": "Action uid for client-portal URLs" },
    "options": { "description": "Provider-specific options object" },
    "icon": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "target": { "type": "string" },
    "lightbox": { "description": "Lightbox configuration when applicable" },
    "order": {
      "type": "integer",
      "description": "Display order (0-based index within the action list)"
    }
  }
}
