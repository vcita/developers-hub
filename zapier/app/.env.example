# Smoke-test config. Copy to `zapier/app/.env` (gitignored) and fill in a token.
# Used by `npm run zapier:smoke` / `npm run zapier:smoke:creates`.
# Real exported env vars take precedence over this file (so CI secrets work too).

# Business staff token. Required to run the smoke test; without it the suite skips.
INTANDEM_SMOKE_TOKEN=

# Opt-in: run Tier 2, which CREATES REAL RECORDS. Use a SANDBOX business only.
# INTANDEM_SMOKE_CREATES=1

# Safety guard for Tier 2: the suite aborts unless the token resolves to this business.
# INTANDEM_SMOKE_BUSINESS_UID=
