      "UpdateVoiceCall": {
        "type": "object",
        "properties": {
          "staff_uid": {
            "type": "string",
            "description": "The unique identifier of the staff member associated with the call (e.g., \"d290f1ee-6c54-4b01-90e6-d701748f0851\")."
          },
          "client_uid": {
            "type": "string",
            "description": "The unique identifier of the client involved in the call (e.g., \"d290f1ee-6c54-4b01-90e6-d701748f0851\")."
          },
          "from_number": {
            "type": "string",
            "description": "The phone number the call originated from, in E.164 format (e.g., \"+14155550148\")."
          },
          "to_number": {
            "type": "string",
            "description": "The phone number the call was directed to, in E.164 format (e.g., \"+14155550901\")."
          },
          "direction": {
            "type": "string",
            "description": "The direction of the call. Must be one of the allowed enum values: INBOUND (incoming call to the business) or OUTBOUND (outgoing call from the business). Values are case-sensitive and must be uppercase (e.g., \"INBOUND\").",
            "enum": [
              "INBOUND",
              "OUTBOUND"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "INCOMING_CALL",
              "ANSWERED_BY_STAFF",
              "MISSED",
              "ANSWERED_BY_CALLS_PROVIDER",
              "MISSED_CALL_HANDLED",
              "VOICEMAIL"
            ],
            "description": "The status of the call. Must be one of the allowed enum values: INCOMING_CALL (call is ringing), ANSWERED_BY_STAFF (staff picked up), MISSED (no one answered), ANSWERED_BY_CALLS_PROVIDER (handled by provider IVR), MISSED_CALL_HANDLED (missed call was followed up), VOICEMAIL (caller left a voicemail). Values are case-sensitive and must be uppercase (e.g., \"MISSED\")."
          },
          "rate": {
            "type": "string",
            "description": "The price rate of the call as a string value (e.g., \"0.05\"). Pass \"0\" for free calls. Must be a string, not a number."
          },
          "price": {
            "type": "string",
            "description": "The total price of the call as a string value (e.g., \"1.50\"). Must be a string, not a number."
          },
          "provider": {
            "type": "string",
            "description": "The voice call provider. Currently only VONAGE is supported. Values are case-sensitive and must be uppercase (e.g., \"VONAGE\").",
            "enum": [
              "VONAGE"
            ]
          },
          "source_id": {
            "type": "string",
            "description": "A unique source identifier for the call from the provider system (e.g., \"call-src-001\")."
          },
          "duration": {
            "type": "number",
            "description": "The duration of the call in seconds (e.g., 120 for a 2-minute call)."
          },
          "call_summary": {
            "type": "string",
            "description": "A text summary of the call content (e.g., \"Client called to ask about their account balance\")."
          },
          "external_app_url": {
            "type": "string",
            "description": "Link to an external application page with additional details about the call (e.g., \"https://example.com/call-details\")."
          },
          "external_app_name": {
            "type": "string",
            "description": "The name of the external application that originated or manages the call."
          },
          "recording_id": {
            "type": "string",
            "description": "The unique identifier of the call recording associated with this voice call."
          },
          "external_uuid": {
            "type": "string",
            "description": "An external unique identifier for the call from the provider system (e.g., \"ext-call-001\")."
          },
          "handled_by_staff_uid": {
            "type": "string",
            "description": "The unique identifier of the staff member who handled or followed up on the call."
          }
        },
        "required": [
          "staff_uid",
          "client_uid",
          "from_number",
          "to_number",
          "direction",
          "status",
          "rate",
          "price",
          "provider",
          "source_id",
          "duration",
          "call_summary",
          "external_app_url",
          "external_app_name",
          "recording_id",
          "external_uuid"
        ]
      },
