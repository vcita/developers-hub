            "description": "Total number of voice calls in the period"
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "description": "Start date of the report period in YYYY-MM-DD format"
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "description": "End date of the report period in YYYY-MM-DD format"
          }
        },
        "required": [
          "status_counts",
          "total_voice_calls",
          "start_date",
          "end_date"
        ]
      }
