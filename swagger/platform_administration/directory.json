              "app_market_url": {"type": "string", "description": "Custom app market URL."},
              "ada_handle": {"type": "string", "description": "ADA chatbot handle code."},
              "pendo": {"type": "string", "description": "Pendo analytics data/configuration.", "nullable": true},
              "chatbot": {"type": "string", "description": "Custom chatbot HTML snippet.", "nullable": true}
