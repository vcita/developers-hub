          },
          "is_trial_allowed": {
            "type": "boolean",
            "description": "Indicates if trial accounts are allowed for this directory."
          },
          "is_slim_register_enabled": {
            "type": "boolean",
            "description": "Indicates if slim registration mode is enabled during onboarding."
          },
          "is_social_links_on": {
            "type": "boolean",
            "description": "Indicates if social links are enabled."
          },
          "locale": {
            "type": "string",
            "description": "Default locale for the directory."
          },
          "time_zone": {
            "type": "string",
            "description": "Default time zone for the directory."
          },
          "paypal_email": {
            "type": "string",
            "description": "PayPal email for the directory."
          },
          "rev_share": {
            "type": "number",
            "description": "Revenue share percentage."
          },
          "rev_share_tier2": {
