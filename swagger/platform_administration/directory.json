              "compliance_in_billing_app": {"type": "boolean", "description": "Whether TOS and privacy policy are visible in the billing app."},
              "enable_upgrade_page_tab": {"type": "string", "description": "Whether the upgrade page opens in a new tab (\"0\" or \"1\")."},
