            "type": "boolean",
            "example": false
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {"type": "string", "description": "The field that caused the error."},
                "code": {"type": "string", "description": "Error code."},
