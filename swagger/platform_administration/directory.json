          "banners_visibility": {
            "type": "string",
            "description": "Controls banner visibility across the directory.",
            "enum": ["show", "hide"],
            "nullable": true
          },
          "only_owner_login_redirect": {
            "type": "boolean",
            "description": "When true, only the business owner is redirected to the logout URL on logout."
          },
          "custom_sms_sending_phone_number": {
            "type": "string",
