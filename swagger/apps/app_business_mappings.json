          "403": {
            "description": "Forbidden - Insufficient permissions or business belongs to a different directory.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "forbidden",
                      "message": "Business belongs to a different directory"
                    }
                  ]
                }
              }
            }
          },
          "409": {
            "description": "Conflict - A mapping already exists for this business and app.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "field": "business_uid",
                      "code": "duplicate",
                      "message": "A mapping already exists for this business_uid and app_code_name"
                    }
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity - Validation error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "field": "app_code_name",
                      "code": "invalid",
                      "message": "app_code_name is not recognized"
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
