{
  "openapi": "3.0.3",
  "info": {
    "title": "App Business Mappings API",
    "description": "API for managing mappings between vcita businesses and third-party integrated app identifiers. Enables partners to associate SMBs with external app business and user codes (e.g., Yext identifiers for app_code_name \"yext\").\n\nAvailable for **Directory tokens**.",
    "version": "3.0.0"
  },
  "servers": [
    {
      "url": "https://api.vcita.biz",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "App Business Mappings",
      "description": "CRUD operations for third-party app business mappings"
    }
  ],
  "paths": {
    "/v3/apps/business_mappings": {
      "get": {
        "tags": ["App Business Mappings"],
        "summary": "List App Business Mappings",
        "description": "Returns a paginated list of app business mappings belonging to the calling directory (resolved from the Directory token). Supports optional filtering by business_uid and app_code_name. Available for **Directory tokens**.",
        "operationId": "listAppBusinessMappings",
        "parameters": [
          {
            "name": "business_uid",
            "in": "query",
            "required": false,
            "description": "Filter by vcita business unique identifier (e.g., \"d290f1ee6c544b01\").",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "app_code_name",
            "in": "query",
            "required": false,
            "description": "Filter by third-party integrated app code name (e.g., \"yext\").",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number of results (e.g., 1, 2, 3).",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000,
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "description": "How many items to return per page. Max: 100 (e.g., 25, 50, 100).",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "App business mappings retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "https://vcita.github.io/developers-hub/entities/response.json"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "business_mappings": {
                              "type": "array",
                              "items": {
                                "$ref": "https://vcita.github.io/developers-hub/entities/apps/appBusinessMapping.json"
                              }
                            }
                          },
                          "required": ["business_mappings"]
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "business_mappings": [
                      {
                        "uid": "abm_7f2e8d9a1b4c",
                        "business_uid": "d290f1ee6c544b01",
                        "directory_uid": "dir_partner_xyz",
                        "app_code_name": "yext",
                        "mapped_business_uid": "yext-business-id-42",
                        "mapped_user_uid": "yext-user-code-42",
                        "created_at": "2026-06-10T10:30:00Z",
                        "updated_at": "2026-06-10T10:30:00Z"
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing bearer token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "unauthorized",
                      "message": "Invalid or expired bearer token"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "forbidden",
                      "message": "Insufficient permissions to list app business mappings"
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      },
      "post": {
