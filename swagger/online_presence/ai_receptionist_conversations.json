{
  "openapi": "3.0.3",
  "info": {
    "title": "Online Presence \u2014 AI Receptionist Conversations",
    "description": "CRUD APIs for AI Receptionist conversations under `/v3/online_presence/ai_receptionist_conversations`.",
    "version": "3.0.2",
    "contact": {}
  },
  "tags": [
    {
      "name": "Online Presence conversations",
      "description": "Persisted AI Receptionist conversations for the authenticated business (**Staff tokens**)."
    }
  ],
  "servers": [
    {
      "url": "https://api.vcita.biz",
      "description": "API Gateway server"
    }
  ],
  "components": {
    "schemas": {
      "ChatTranscriptDocument": {
        "type": "object",
        "description": "Structured transcript object captured when a session ends. Uses the same visitor-visible message list shape returned by chat session resume APIs.",
        "properties": {
          "schemaVersion": {
            "type": "integer",
            "enum": [
              1
            ],
            "description": "Document format version."
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatVisitorMessage"
            },
            "description": "Ordered visitor-visible turns."
          }
        },
        "required": [
          "schemaVersion",
          "messages"
        ],
        "example": {
          "schemaVersion": 1,
          "messages": [
            {
              "role": "assistant",
              "content": "Hi! How can I help?",
              "at": "2026-04-19T12:34:56.789Z"
            },
            {
              "role": "user",
              "content": "I need to book an appointment.",
              "at": "2026-04-19T12:35:01.000Z"
            }
          ]
        }
      },
      "ChatVisitorMessage": {
        "type": "object",
        "description": "Visitor-visible chat line (**user** or **assistant**). Used in chat resume responses and stored inside `ChatTranscriptDocument` for persisted conversations. System prompts and internal tool rows are not included.",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ],
            "description": "Who sent the message."
          },
          "content": {
            "type": "string",
            "description": "Message text (may include markdown)."
          },
          "at": {
            "type": "string",
            "format": "date-time",
            "description": "Optional ISO 8601 UTC timestamp when the server recorded the turn. May be omitted on older Redis session blobs; clients may use it for ordering or display outside the embeddable widget."
          }
        },
        "required": [
          "role",
          "content"
        ],
        "example": {
          "role": "assistant",
          "content": "Hi! How can I help you today?",
          "at": "2026-04-19T12:34:56.789Z"
        }
      },
      "VoiceConversationMetadata": {
        "type": "object",
        "nullable": true,
        "description": "Voice-specific metadata for AI Receptionist calls, including caller/callee numbers and recording details when available.",
        "properties": {
          "voice_call_uid": {
            "type": "string",
            "nullable": true,
            "description": "Internal voicecalls call UID."
          },
          "external_uuid": {
            "type": "string",
            "nullable": true,
            "description": "External provider conversation UUID."
          },
          "from_number": {
            "type": "string",
            "nullable": true,
            "description": "Caller phone number in E.164 format."
          },
          "to_number": {
            "type": "string",
            "nullable": true,
            "description": "Dialed voicecalls phone number in E.164 format."
          },
          "recording_url": {
            "type": "string",
            "nullable": true,
            "description": "Signed call recording URL generated by voicecalls."
          },
          "file_size": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "description": "Recording file size in bytes."
          },
          "recording_duration": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "description": "Recording duration in seconds."
          },
          "recording_received_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Time when webaiwidgetserver received the recording callback."
          }
        }
      },
      "CreateConversationRequest": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "maxLength": 255,
            "description": "Chat session identifier associated with this persisted conversation."
          },
          "business_uid": {
            "type": "string",
            "maxLength": 255,
            "description": "Business UID for this conversation. Must match the authenticated business context."
          },
          "transcript": {
            "description": "Structured transcript JSON (`ChatTranscriptDocument`) when closing a session; optional JSON string encoding for compatibility.",
            "nullable": true,
            "oneOf": [
              {
                "$ref": "#/components/schemas/ChatTranscriptDocument"
              },
              {
                "type": "string"
              }
            ]
          },
          "summary": {
            "type": "string",
            "nullable": true,
            "description": "Optional summary of the conversation."
          },
          "contact_full_name": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Visitor full name captured during the chat."
          },
          "contact_email": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Visitor email captured during the chat."
          },
          "contact_phone": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Visitor phone captured during the chat."
          },
          "page_url": {
            "type": "string",
            "nullable": true,
            "description": "Page URL where the chat was started."
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "Conversation start timestamp in ISO 8601 format."
          },
          "ended_at": {
            "type": "string",
            "format": "date-time",
            "description": "Conversation end timestamp in ISO 8601 format."
          },
          "matter_uid": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Optional related matter/case UID."
          },
          "client_uid": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Optional CRM client UID linked to this conversation."
          },
          "message_count": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "description": "Number of visitor-visible messages in the conversation."
          },
          "lead_intent": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Lead intent extracted or assigned for this conversation (e.g., \"General inquiry\")."
          },
          "lead_information": {
            "type": "object",
            "nullable": true,
            "description": "Lead key/value data captured from the conversation.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "source_app_uid": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Application that delivered the inbound traffic for this conversation."
          },
          "channel_uid": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Channel identifier used for attribution in AI Receptionist reporting."
          },
          "delivery_kind": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "enum": [
              "webaiwidgetmgr",
              "comm_gw",
              "voicecalls"
            ],
            "description": "Lifecycle owner for the conversation."
          },
          "voice_call_uid": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Internal voicecalls call UID used to correlate voice callbacks."
          },
          "external_uuid": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "External provider conversation UUID, usually the Vonage conversation UUID."
          },
          "voice_metadata": {
            "$ref": "#/components/schemas/VoiceConversationMetadata"
          }
        },
        "required": [
          "session_id",
          "business_uid",
          "started_at",
          "ended_at"
        ]
      },
      "ListConversationsPayload": {
        "type": "object",
        "properties": {
          "conversations": {
            "type": "array",
            "description": "Conversations for the authenticated business on the current page.",
            "items": {
              "$ref": "https://vcita.github.io/developers-hub/entities/online_presence/AiReceptionistConversation.json"
            }
          },
          "total": {
            "type": "integer",
            "minimum": 0,
            "description": "Total number of conversations across all pages."
          }
        },
        "required": [
          "conversations",
          "total"
        ]
      },
      "NestHttpException": {
        "type": "object",
        "description": "Standard v3 error envelope for online_presence chat APIs.",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Always false for error responses.",
            "enum": [
              false
            ]
          },
          "errors": {
            "type": "array",
            "description": "List of error details describing what failed.",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "nullable": true,
                  "description": "Request field that failed validation, when applicable."
                },
                "code": {
                  "type": "string",
                  "description": "Machine-readable error code."
                },
                "message": {
                  "type": "string",
                  "description": "Human-readable error message."
                }
              },
              "required": [
                "code",
                "message"
              ]
            }
          }
        },
        "required": [
          "success",
          "errors"
        ]
      },
      "UpdateConversationRequest": {
        "type": "object",
        "properties": {
          "transcript": {
            "description": "Structured transcript or JSON string; optional staff edits.",
            "nullable": true,
            "oneOf": [
              {
                "$ref": "#/components/schemas/ChatTranscriptDocument"
              },
              {
                "type": "string"
              }
            ]
          },
          "summary": {
            "type": "string",
            "nullable": true,
            "description": "Optional summary of the conversation."
          },
          "contact_full_name": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Visitor full name captured during the chat."
          },
          "contact_email": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Visitor email captured during the chat."
          },
          "contact_phone": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Visitor phone captured during the chat."
          },
          "page_url": {
            "type": "string",
            "nullable": true,
            "description": "Page URL where the chat was started."
          },
          "matter_uid": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Optional related matter/case UID."
          },
          "lead_intent": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Lead intent value for staff edits."
          },
          "lead_information": {
            "type": "object",
            "nullable": true,
            "description": "Lead key/value data for staff edits.",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "**Staff tokens** \u2014 business context is taken from the token for conversations."
      }
    }
  },
  "paths": {
    "/v3/online_presence/ai_receptionist_conversations": {
      "get": {
        "operationId": "listAiReceptionistConversations",
        "summary": "Get all conversations",
        "description": "Returns paginated conversations for the authenticated business. **Staff tokens** required.",
        "tags": [
          "Online Presence conversations"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "1-based page index.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of records per page (1-100).",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Search in transcript and summary",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include_simulated",
            "in": "query",
            "description": "When true, includes conversations created by AI Receptionist simulation and training flows. Simulated conversations are excluded by default.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort expression in `field:asc|desc` format. Allowed fields: `ended_at`, `started_at`, `created_at`, `updated_at`. Default sort is `ended_at:desc`.",
            "schema": {
              "type": "string",
              "example": "ended_at:desc"
            }
          },
          {
            "name": "from_date",
            "in": "query",
            "description": "Filter conversations ending on or after this ISO 8601 date-time.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to_date",
            "in": "query",
            "description": "Filter conversations ending on or before this ISO 8601 date-time.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List result (`{ success: true, data: { conversations, total } }`)",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "https://vcita.github.io/developers-hub/entities/response.json"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ListConversationsPayload"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Malformed request syntax",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "422": {
            "description": "Validation failure (e.g., invalid sort parameter)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "field": "sort",
                      "code": "invalid",
                      "message": "sort field must be one of: ended_at, started_at, created_at, updated_at"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "unauthorized",
                      "message": "Authentication required"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Business context required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "forbidden",
                      "message": "Business context required"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createAiReceptionistConversation",
        "summary": "Create a conversation",
        "description": "Creates a conversation for the authenticated business. **Staff tokens** required.",
        "tags": [
          "Online Presence conversations"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateConversationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created (`{ success: true, data: conversation }`)",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "https://vcita.github.io/developers-hub/entities/response.json"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "https://vcita.github.io/developers-hub/entities/online_presence/AiReceptionistConversation.json"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Malformed request syntax",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "422": {
            "description": "Validation failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "field": "ended_at",
                      "code": "invalid",
                      "message": "ended_at must be a valid ISO 8601 date string"
                    },
                    {
                      "field": "started_at",
                      "code": "invalid",
                      "message": "started_at must be a valid ISO 8601 date string"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "unauthorized",
                      "message": "Authentication required"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Forbidden \u2014 business mismatch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "field": "business_uid",
                      "code": "forbidden",
                      "message": "business_uid does not match authenticated business"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v3/online_presence/ai_receptionist_conversations/{uid}": {
      "get": {
        "operationId": "getAiReceptionistConversation",
        "summary": "Retrieve a conversation",
        "description": "Returns a single conversation by uid for the authenticated business. **Staff tokens** required.",
        "tags": [
          "Online Presence conversations"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation (`{ success: true, data: conversation }`)",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "https://vcita.github.io/developers-hub/entities/response.json"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "https://vcita.github.io/developers-hub/entities/online_presence/AiReceptionistConversation.json"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "unauthorized",
                      "message": "Authentication required"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "forbidden",
                      "message": "Access denied"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "not_found",
                      "message": "Conversation not found"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateAiReceptionistConversation",
        "summary": "Update a conversation",
        "description": "Updates a conversation by uid. **Staff tokens** required.",
        "tags": [
          "Online Presence conversations"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateConversationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated conversation",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "https://vcita.github.io/developers-hub/entities/response.json"
                    },
                    {
                      "properties": {
                        "data": {
                          "$ref": "https://vcita.github.io/developers-hub/entities/online_presence/AiReceptionistConversation.json"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "unauthorized",
                      "message": "Authentication required"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "forbidden",
                      "message": "Access denied"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "code": "not_found",
                      "message": "Conversation not found"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAiReceptionistConversation",
        "summary": "Delete a conversation",
        "description": "Soft-deletes a conversation and returns the soft-deleted conversation (`{ success: true, data }`). **Staff tokens** required.",
        "tags": [
          "Online Presence conversations"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The soft-deleted conversation (`{ success: true, data }`)",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "https://vcita.github.io/developers-hub/entities/response.json"
                    },
                    {
