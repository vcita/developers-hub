          },
          "include_booking_policies": {
            "type": "boolean",
            "nullable": true
          },
          "include_terms_of_service": {
            "type": "boolean",
            "nullable": true
          },
          "guidance_urls": {
            "type": "array",
            "nullable": true,
            "items": {
