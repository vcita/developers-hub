            "nullable": true,
            "maxLength": 50000
          },
          "business_hours": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000
          },
          "welcome_message": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000
          },
          "brand_color": {
            "type": "string",
            "nullable": true
          },
          "text_color": {
            "type": "string",
            "nullable": true
          },
          "logo_url": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "actions": {
            "type": "array",
            "nullable": true,
            "description": "Ordered action list. Each item includes `uid`, `action`, `availability`, optional `label`, optional `should_offer`, and optional `when_to_offer`.",
            "items": {
              "$ref": "#/components/schemas/ActionConfigItem"
            }
          },
          "auto_popup_enabled": {
            "type": "boolean",
            "nullable": true
          },
          "auto_popup_delay": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 3600
          },
          "welcome_buttons": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/WelcomeButton"
            }
          },
          "lead_capture_text": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000
          },
          "lead_intent_data": {
            "type": "array",
            "nullable": true,
            "maxItems": 10,
