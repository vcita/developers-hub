      "WidgetConfigurationResource": {
        "$ref": "https://vcita.github.io/developers-hub/entities/online_presence/WidgetConfiguration.json"
      },
      "SingleWidgetConfigurationPayload": {
        "type": "object",
        "properties": {
          "widget_configuration": {
            "$ref": "#/components/schemas/WidgetConfigurationResource"
          }
        },
        "required": [
          "widget_configuration"
        ]
      },
      "ListWidgetConfigurationsPayload": {
        "type": "object",
        "properties": {
          "widget_configurations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WidgetConfigurationResource"
            }
          },
          "total": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "widget_configurations",
          "total"
        ]
      },
      "ResolvedPublicConfigAction": {
        "type": "object",
        "description": "Resolved action for public embed: merged portal + widget overrides (snake_case).",
        "properties": {
          "name": {
            "type": "string",
            "description": "Action key/name"
          },
          "action": {
            "type": "string",
            "description": "Action type/key"
          },
          "text": {
            "type": "string",
            "description": "Display label"
          },
          "uid": {
            "type": "string",
            "description": "Action uid for client-portal URLs"
          },
          "options": {
            "description": "Provider-specific options object"
          },
          "icon": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "target": {
            "type": "string"
          },
          "lightbox": {
            "description": "Lightbox configuration when applicable"
          },
          "order": {
            "type": "integer",
            "description": "Display order (0-based index within the action list)"
          }
        }
      },
      "ResolvedPublicConfig": {
        "type": "object",
        "description": "Merged public-facing Web AI Widget configuration for embed/live site (`GET .../public/:widget_uid`). All listed fields are present in responses. `portal_host` is injected server-side for action/lightbox URLs. Returned inside standard `data` after the Response wrapper.",
        "properties": {
          "uid": {
            "type": "string",
            "description": "Widget configuration UID."
          },
          "business_uid": {
            "type": "string",
            "description": "Owning business UID."
          },
          "widget_title": {
            "type": "string",
            "description": "Widget header title."
          },
          "brand_color": {
            "type": "string",
            "description": "Brand/theme color (hex)."
          },
          "text_color": {
            "type": "string",
            "description": "Text color (hex)."
          },
          "logo_url": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "Logo URL."
          },
          "button_text": {
            "type": "string",
            "description": "Engage button label."
          },
          "auto_popup_enabled": {
            "type": "boolean",
            "description": "Whether the widget auto-opens."
          },
          "auto_popup_delay": {
            "type": "integer",
            "description": "Auto-popup delay in milliseconds."
          },
          "actions": {
            "type": "array",
            "description": "Ordered list of resolved actions.",
            "items": {
              "$ref": "#/components/schemas/ResolvedPublicConfigAction"
            }
          },
          "welcome_message": {
            "type": "string",
            "description": "Message shown when chat opens."
          },
          "welcome_buttons": {
            "type": "array",
            "description": "Quick-reply buttons under the welcome message.",
            "items": {
              "$ref": "#/components/schemas/WelcomeButton"
            }
          },
          "portal_host": {
            "type": "string",
            "description": "Portal host base URL injected for action/lightbox links (not stored per widget)."
