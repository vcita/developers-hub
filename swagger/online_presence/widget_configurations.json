{
  "openapi": "3.0.3",
  "info": {
    "title": "Web AI Widget \u2014 Widget configurations",
    "description": "Manage embedded Web AI Widget configurations per business (CRUD, main upsert, public resolved config for embed, AI guidance markdown). Successful JSON responses use the standard `{ success, data }` envelope from the API gateway + `@vcita/infra-nestjs` response interceptor, except where noted (markdown body). Service: **webaiwidgetmgr**. Non-CRUD actions (`main`, `public`, `ai_guidance`) are internal/private and not part of the public CRUD contract.",
    "version": "3.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Web AI Widget",
      "description": "Widget configuration resources under `/v3/online_presence/widget_configurations`."
    }
  ],
  "servers": [
    {
      "url": "https://api.vcita.biz",
      "description": "API Gateway server"
    }
  ],
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "success",
          "errors"
        ]
      },
      "NestHttpException": {
        "type": "object",
        "description": "Standard v3 error envelope.",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              false
            ]
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "nullable": true
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              },
              "required": [
                "code",
                "message"
              ]
            }
          }
        },
        "required": [
          "success",
          "errors"
        ]
      },
      "WelcomeButton": {
        "type": "object",
        "description": "Quick-reply button shown under the welcome message in the Web AI Widget.",
        "properties": {
          "label": {
            "type": "string",
            "description": "Button label shown to the visitor."
          },
          "message": {
            "type": "string",
            "description": "Message text sent to the assistant when the button is clicked."
          }
        },
        "required": [
          "label",
          "message"
        ]
      },
      "ActionConfigItem": {
        "type": "object",
        "description": "A single client-portal action in the stored widget configuration. Order follows array position in the API.",
        "properties": {
          "uid": {
            "type": "string",
            "nullable": true,
            "description": "Portal action UID. Required by the API for persisted actions; nullable only for legacy/backfill reads."
          },
          "action": {
            "type": "string",
            "description": "Action key/type (client-portal action identifier)."
          },
          "label": {
            "type": "string",
            "nullable": true,
            "maxLength": 200,
            "description": "Display label override; omit or null to resolve from portal defaults."
          },
          "availability": {
            "type": "boolean",
            "description": "Whether this action is available in the widget."
          },
          "should_offer": {
            "type": "boolean",
            "nullable": true,
            "description": "Whether the assistant should proactively suggest this action."
          },
          "when_to_offer": {
            "type": "string",
            "nullable": true,
            "maxLength": 200,
            "description": "Guidance text for when the assistant should proactively suggest this action."
          }
        },
        "required": [
          "uid",
          "action",
          "availability"
        ]
      },
      "LeadIntentDataItem": {
        "type": "object",
        "description": "Intent-based lead capture instructions used by the Web AI Widget assistant. Each item defines one intent and the data that should be collected for it.",
        "properties": {
          "lead_intent": {
            "type": "string",
            "nullable": true,
            "maxLength": 100,
            "description": "Lead intent name (e.g., \"General inquiry\", \"Book consultation\"). Null/empty resolves to defaults according to backend normalization rules."
          },
          "lead_data_items": {
            "type": "string",
            "nullable": true,
            "maxLength": 200,
            "description": "Comma-separated or free-text list of lead fields to collect for this intent."
          },
          "lead_message_to_visitor": {
            "type": "string",
            "nullable": true,
            "maxLength": 200,
            "description": "Guidance text for how the assistant should explain what is being collected and what happens next while capturing lead details."
          }
        }
      },
      "RequestCreateWidgetConfiguration": {
        "type": "object",
        "properties": {
          "business_uid": {
            "type": "string",
            "description": "Business scope; must match the authenticated Business token."
          },
          "widget_title": {
            "type": "string",
            "nullable": true,
            "maxLength": 200
          },
          "faq_and_guidance": {
            "type": "string",
            "nullable": true,
            "maxLength": 50000
          },
          "business_hours": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000
          },
          "welcome_message": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000
          },
          "brand_color": {
            "type": "string",
            "nullable": true,
            "description": "Hex color"
          },
          "text_color": {
            "type": "string",
            "nullable": true,
            "description": "Hex color"
          },
          "logo_url": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "actions": {
            "type": "array",
            "nullable": true,
            "description": "Ordered action list. Each item includes `uid`, `action`, `availability`, optional `label`, optional `should_offer`, and optional `when_to_offer`.",
            "items": {
              "$ref": "#/components/schemas/ActionConfigItem"
            }
          },
          "auto_popup_enabled": {
            "type": "boolean",
            "nullable": true
          },
          "auto_popup_delay": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 3600
          },
          "welcome_buttons": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/WelcomeButton"
            }
          },
          "lead_capture_text": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000
          },
          "lead_intent_data": {
            "type": "array",
            "nullable": true,
            "maxItems": 10,
            "items": {
              "$ref": "#/components/schemas/LeadIntentDataItem"
            }
          },
          "button_text": {
            "type": "string",
            "nullable": true,
            "maxLength": 200
          },
          "include_contact_info": {
            "type": "boolean",
            "nullable": true
          },
          "include_services": {
            "type": "boolean",
            "nullable": true
          },
          "include_products": {
            "type": "boolean",
            "nullable": true
          },
          "include_booking_policies": {
            "type": "boolean",
            "nullable": true
          },
          "include_terms_of_service": {
            "type": "boolean",
            "nullable": true
          },
          "guidance_urls": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "string",
              "format": "uri",
              "maxLength": 2048
            }
          }
        },
        "required": [
          "business_uid"
        ]
      },
