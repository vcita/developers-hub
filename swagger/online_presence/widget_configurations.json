                },
                "example": {
                  "success": true,
                  "data": {
                    "widget_configuration": {
                      "uid": "widcfg_48b3f7a2",
                      "business_uid": "biz_2f8f7ab1",
                      "widget_title": "Acme Plumbing AI Assistant",
                      "welcome_message": "Hi! Need help with plumbing services?",
                      "brand_color": "#1f7ae0",
                      "text_color": "#ffffff",
                      "button_text": "Chat with us",
                      "created_at": "2026-04-22T10:30:00.000Z",
                      "updated_at": "2026-04-22T11:12:45.000Z"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "404": {
            "description": "No main widget configuration for this business",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          }
        },
        "x-internal": true
      },
      "put": {
        "operationId": "putMainWidgetConfiguration",
        "summary": "Create or update main widget configuration",
        "description": "[Internal use only] Upserts the main configuration for a business. **Business token** required; optional **Staff token** for attribution.",
        "tags": [
          "Web AI Widget"
        ],
        "security": [
          {
            "Bearer": []
          }
