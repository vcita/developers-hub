    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Business token (and optional Staff token where the API supports attribution). `business_uid` in query/body must match the authenticated business."
      }
    }
  },
  "paths": {
    "/v3/online_presence/widget_configurations": {
      "get": {
        "operationId": "listWidgetConfigurations",
        "summary": "Get all widget configurations",
        "description": "Lists configurations for a business. **Business token** required; `business_uid` query must match the token. Pagination: 1-based `page`, `per_page` (1\u2013100). Optional `sort=field:asc|desc` (first segment only); allowed fields: `created_at`, `updated_at`, `business_uid`. Legacy `order_by` / `order_dir` are rejected.",
        "tags": [
          "Web AI Widget"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "name": "business_uid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "1-based page index",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "e.g. `created_at:desc` or `updated_at:asc`. Direction defaults to `asc` if omitted.",
            "schema": {
              "type": "string",
              "example": "created_at:desc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List result",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "https://vcita.github.io/developers-hub/entities/response.json"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ListWidgetConfigurationsPayload"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "widget_configurations": [
                      {
                        "uid": "widcfg_48b3f7a2",
                        "business_uid": "biz_2f8f7ab1",
                        "created_at": "2026-04-22T10:30:00.000Z",
                        "updated_at": "2026-04-22T11:12:45.000Z",
                        "widget_title": "Acme Plumbing AI Assistant",
                        "brand_color": "#1f7ae0",
                        "text_color": "#ffffff",
                        "auto_popup_enabled": true,
                        "auto_popup_delay": 8,
                        "button_text": "Chat with us"
                      }
                    ],
                    "total": 1
                  }
                }
              }
            }
          },
          "422": {
            "description": "Semantic validation or bad query (e.g. legacy sort params)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "field": "sort",
                      "code": "invalid",
                      "message": "sort field must be one of: created_at, updated_at, business_uid"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden \u2014 business mismatch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "404": {
            "description": "Not found (masked as 404 for business mismatch in some cases)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createWidgetConfiguration",
        "summary": "Create widget configuration",
        "description": "Creates a configuration row. **Business token** required; optional **Staff token** for attribution (`owner_id`).",
        "tags": [
          "Web AI Widget"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestCreateWidgetConfiguration"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "https://vcita.github.io/developers-hub/entities/response.json"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/SingleWidgetConfigurationPayload"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "widget_configuration": {
                      "uid": "widcfg_48b3f7a2",
                      "business_uid": "biz_2f8f7ab1",
                      "created_at": "2026-04-22T10:30:00.000Z",
                      "updated_at": "2026-04-22T10:30:00.000Z",
                      "widget_title": "Acme Plumbing AI Assistant",
                      "welcome_message": "Hi! Need help with plumbing services?",
                      "brand_color": "#1f7ae0",
                      "text_color": "#ffffff",
                      "button_text": "Chat with us"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Malformed request syntax (e.g., invalid JSON payload)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "422": {
            "description": "Semantic validation or business-rule failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestHttpException"
                }
              }
            }
          }
        }
      }
    },
    "/v3/online_presence/widget_configurations/main": {
      "get": {
        "operationId": "getMainWidgetConfiguration",
        "summary": "Retrieve main widget configuration",
        "description": "[Internal use only] Returns the primary widget configuration for the business. **Business token** required.",
