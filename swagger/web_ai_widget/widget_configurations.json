{
  "openapi": "3.0.3",
  "info": {
    "title": "Web AI Widget — Widget configurations",
    "description": "Manage embedded Web AI Widget configurations per business (CRUD, main upsert, public resolved config for embed, AI guidance markdown). Successful JSON responses use the standard `{ success, data }` envelope from the API gateway + `@vcita/infra-nestjs` response interceptor, except where noted (markdown body). Service: **webaiwidgetmgr**.",
    "version": "3.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Web AI Widget",
      "description": "Widget configuration resources under `/v3/clientportal/web_ai_widget/widget_configurations`."
    }
  ],
  "servers": [
    {
      "url": "https://api.vcita.biz",
      "description": "API Gateway server"
    }
  ],
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": ["success", "errors"]
      },
      "NestHttpException": {
        "type": "object",
        "description": "Standard v3 error envelope.",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [false]
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string", "nullable": true },
                "code": { "type": "string" },
                "message": { "type": "string" }
              },
              "required": ["code", "message"]
            }
          }
        },
        "required": ["success", "errors"]
      },
      "WelcomeButton": {
        "$ref": "https://vcita.github.io/developers-hub/entities/web_ai_widget/WidgetWelcomeButton.json"
      },
      "ActionConfigItem": {
        "$ref": "https://vcita.github.io/developers-hub/entities/web_ai_widget/WidgetConfigurationAction.json"
      },
      "LeadIntentDataItem": {
        "$ref": "https://vcita.github.io/developers-hub/entities/web_ai_widget/LeadIntentDataItem.json"
      },
      "RequestCreateWidgetConfiguration": {
        "type": "object",
        "properties": {
          "business_uid": { "type": "string", "description": "Business scope; must match the authenticated Business token." },
          "widget_title": { "type": "string", "nullable": true, "maxLength": 200 },
          "faq_and_guidance": { "type": "string", "nullable": true, "maxLength": 50000 },
          "business_hours": { "type": "string", "nullable": true, "maxLength": 1000 },
          "welcome_message": { "type": "string", "nullable": true, "maxLength": 1000 },
          "brand_color": { "type": "string", "nullable": true, "description": "Hex color" },
          "text_color": { "type": "string", "nullable": true, "description": "Hex color" },
          "logo_url": { "type": "string", "nullable": true, "format": "uri" },
          "actions": {
            "type": "array",
            "nullable": true,
            "description": "Ordered action list. Each item includes `uid`, `action`, `availability`, optional `label`, optional `should_offer`, and optional `when_to_offer`.",
            "items": { "$ref": "#/components/schemas/ActionConfigItem" }
          },
          "auto_popup_enabled": { "type": "boolean", "nullable": true },
          "auto_popup_delay": { "type": "number", "nullable": true, "minimum": 0, "maximum": 3600 },
          "welcome_buttons": {
            "type": "array",
            "nullable": true,
            "items": { "$ref": "#/components/schemas/WelcomeButton" }
          },
          "lead_capture_text": { "type": "string", "nullable": true, "maxLength": 1000 },
          "lead_intent_data": {
            "type": "array",
            "nullable": true,
            "maxItems": 10,
            "items": { "$ref": "#/components/schemas/LeadIntentDataItem" }
          },
          "button_text": { "type": "string", "nullable": true, "maxLength": 200 },
          "include_contact_info": { "type": "boolean", "nullable": true },
          "include_services": { "type": "boolean", "nullable": true },
          "include_products": { "type": "boolean", "nullable": true },
          "include_booking_policies": { "type": "boolean", "nullable": true },
          "include_terms_of_service": { "type": "boolean", "nullable": true },
          "guidance_urls": {
            "type": "array",
            "nullable": true,
            "items": { "type": "string", "format": "uri", "maxLength": 2048 }
          }
        },
        "required": ["business_uid"]
      },
      "RequestUpdateWidgetConfiguration": {
        "type": "object",
        "description": "Partial update; all fields optional. `business_uid` may be sent for validation.",
        "properties": {
          "business_uid": { "type": "string" },
          "widget_title": { "type": "string", "nullable": true, "maxLength": 200 },
          "faq_and_guidance": { "type": "string", "nullable": true, "maxLength": 50000 },
          "business_hours": { "type": "string", "nullable": true, "maxLength": 1000 },
          "welcome_message": { "type": "string", "nullable": true, "maxLength": 1000 },
          "brand_color": { "type": "string", "nullable": true },
          "text_color": { "type": "string", "nullable": true },
          "logo_url": { "type": "string", "nullable": true, "format": "uri" },
          "actions": {
            "type": "array",
            "nullable": true,
            "description": "Ordered action list. Each item includes `uid`, `action`, `availability`, optional `label`, optional `should_offer`, and optional `when_to_offer`.",
            "items": { "$ref": "#/components/schemas/ActionConfigItem" }
          },
          "auto_popup_enabled": { "type": "boolean", "nullable": true },
          "auto_popup_delay": { "type": "number", "nullable": true, "minimum": 0, "maximum": 3600 },
          "welcome_buttons": {
            "type": "array",
            "nullable": true,
            "items": { "$ref": "#/components/schemas/WelcomeButton" }
          },
          "lead_capture_text": { "type": "string", "nullable": true, "maxLength": 1000 },
          "lead_intent_data": {
            "type": "array",
            "nullable": true,
            "maxItems": 10,
            "items": { "$ref": "#/components/schemas/LeadIntentDataItem" }
          },
          "button_text": { "type": "string", "nullable": true, "maxLength": 200 },
          "include_contact_info": { "type": "boolean", "nullable": true },
          "include_services": { "type": "boolean", "nullable": true },
          "include_products": { "type": "boolean", "nullable": true },
          "include_booking_policies": { "type": "boolean", "nullable": true },
          "include_terms_of_service": { "type": "boolean", "nullable": true },
          "guidance_urls": {
            "type": "array",
            "nullable": true,
            "items": { "type": "string", "format": "uri", "maxLength": 2048 }
          }
        }
      },
      "WidgetConfigurationResource": {
        "$ref": "https://vcita.github.io/developers-hub/entities/web_ai_widget/WidgetConfiguration.json"
      },
      "SingleWidgetConfigurationPayload": {
        "type": "object",
        "properties": {
          "widget_configuration": {
            "$ref": "#/components/schemas/WidgetConfigurationResource"
          }
        },
        "required": ["widget_configuration"]
      },
      "ListWidgetConfigurationsPayload": {
        "type": "object",
        "properties": {
          "widget_configurations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/WidgetConfigurationResource" }
          },
          "total": { "type": "integer", "minimum": 0 }
        },
        "required": ["widget_configurations", "total"]
      },
      "ResolvedPublicConfigAction": {
        "$ref": "https://vcita.github.io/developers-hub/entities/web_ai_widget/ResolvedPublicWidgetAction.json"
      },
      "ResolvedPublicConfig": {
        "$ref": "https://vcita.github.io/developers-hub/entities/web_ai_widget/ResolvedPublicWidgetConfig.json"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Business token (and optional Staff token where the API supports attribution). `business_uid` in query/body must match the authenticated business."
      }
    }
  },
  "paths": {
    "/v3/clientportal/web_ai_widget/widget_configurations": {
      "get": {
        "operationId": "listWidgetConfigurations",
        "summary": "Get all widget configurations",
        "description": "Lists configurations for a business. **Business token** required; `business_uid` query must match the token. Pagination: 1-based `page`, `per_page` (1–100). Optional `sort=field:asc|desc` (first segment only); allowed fields: `created_at`, `updated_at`, `business_uid`. Legacy `order_by` / `order_dir` are rejected.",
        "tags": ["Web AI Widget"],
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "name": "business_uid",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "1-based page index",
            "schema": { "type": "integer", "minimum": 1, "default": 1 }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "e.g. `created_at:desc` or `updated_at:asc`. Direction defaults to `asc` if omitted.",
            "schema": { "type": "string", "example": "created_at:desc" }
          }
        ],
        "responses": {
          "200": {
            "description": "List result",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/ListWidgetConfigurationsPayload" }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "widget_configurations": [
                      {
                        "uid": "widcfg_48b3f7a2",
                        "business_uid": "biz_2f8f7ab1",
                        "created_at": "2026-04-22T10:30:00.000Z",
                        "updated_at": "2026-04-22T11:12:45.000Z",
                        "widget_title": "Acme Plumbing AI Assistant",
                        "brand_color": "#1f7ae0",
                        "text_color": "#ffffff",
                        "auto_popup_enabled": true,
                        "auto_popup_delay": 8,
                        "button_text": "Chat with us"
                      }
                    ],
                    "total": 1
                  }
                }
              }
            }
          },
          "422": {
            "description": "Semantic validation or bad query (e.g. legacy sort params)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" },
                "example": {
                  "success": false,
                  "errors": [
                    {
                      "field": "sort",
                      "code": "invalid",
                      "message": "sort field must be one of: created_at, updated_at, business_uid"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "403": {
            "description": "Forbidden — business mismatch",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "404": {
            "description": "Not found (masked as 404 for business mismatch in some cases)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createWidgetConfiguration",
        "summary": "Create widget configuration",
        "description": "Creates a configuration row. **Business token** required; optional **Staff token** for attribution (`owner_id`).",
        "tags": ["Web AI Widget"],
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RequestCreateWidgetConfiguration" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/SingleWidgetConfigurationPayload" }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "widget_configuration": {
                      "uid": "widcfg_48b3f7a2",
                      "business_uid": "biz_2f8f7ab1",
                      "created_at": "2026-04-22T10:30:00.000Z",
                      "updated_at": "2026-04-22T10:30:00.000Z",
                      "widget_title": "Acme Plumbing AI Assistant",
                      "welcome_message": "Hi! Need help with plumbing services?",
                      "brand_color": "#1f7ae0",
                      "text_color": "#ffffff",
                      "button_text": "Chat with us"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Malformed request syntax (e.g., invalid JSON payload)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "422": {
            "description": "Semantic validation or business-rule failure",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          }
        }
      }
    },
    "/v3/clientportal/web_ai_widget/widget_configurations/main": {
      "get": {
        "operationId": "getMainWidgetConfiguration",
        "summary": "Retrieve main widget configuration",
        "description": "Returns the primary widget configuration for the business. **Business token** required.",
        "tags": ["Web AI Widget"],
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "name": "business_uid",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Main configuration",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/SingleWidgetConfigurationPayload" }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "widget_configuration": {
                      "uid": "widcfg_48b3f7a2",
