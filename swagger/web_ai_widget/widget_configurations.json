                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "404": {
            "description": "No main widget configuration for this business",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "putMainWidgetConfiguration",
        "summary": "Create or update main widget configuration",
        "description": "Upserts the main configuration for a business. **Business token** required; optional **Staff token** for attribution.",
        "tags": ["Web AI Widget"],
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RequestCreateWidgetConfiguration" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upserted configuration",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/SingleWidgetConfigurationPayload" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Malformed request syntax (e.g., invalid JSON payload)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "422": {
            "description": "Semantic validation or business-rule failure",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          }
        }
      }
    },
    "/v3/clientportal/web_ai_widget/widget_configurations/public/{widget_uid}": {
      "get": {
        "operationId": "getResolvedPublicWidgetConfiguration",
        "summary": "Get resolved public widget config",
        "description": "Public embed endpoint (no end-user bearer). Resolved merged config for live site / widget by `widget_uid`. **Cache-Control: public, max-age=60.** Gateway may whitelist this path without introspection.",
        "tags": ["Web AI Widget"],
        "security": [],
        "parameters": [
          {
            "name": "widget_uid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved public configuration",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/ResolvedPublicConfig" }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "uid": "widcfg_48b3f7a2",
                    "business_uid": "biz_2f8f7ab1",
                    "widget_title": "Acme Plumbing AI Assistant",
                    "brand_color": "#1f7ae0",
                    "text_color": "#ffffff",
                    "logo_url": "https://cdn.example.com/acme/logo.png",
                    "button_text": "Chat with us",
                    "auto_popup_enabled": true,
                    "auto_popup_delay": 8000,
                    "actions": [],
                    "welcome_message": "Hi! Need help with plumbing services?",
                    "welcome_buttons": [
                      { "label": "Book an appointment", "message": "I want to book an appointment." }
                    ],
                    "portal_host": "clients.vcita.com"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Unknown widget uid",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          }
        }
      }
    },
    "/v3/clientportal/web_ai_widget/widget_configurations/public": {
      "get": {
        "operationId": "getResolvedPublicMainWidgetConfigurationByBusinessUid",
        "summary": "Get resolved public main widget config by business",
        "description": "Public embed endpoint (no end-user bearer). Returns merged main widget config for a business using `business_uid`. **Cache-Control: public, max-age=60.**",
        "tags": ["Web AI Widget"],
        "security": [],
        "parameters": [
          {
            "name": "business_uid",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Resolved public main configuration",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/ResolvedPublicConfig" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Missing or invalid `business_uid` query parameter",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "404": {
            "description": "No widget configuration found for business",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          }
        }
      }
    },
    "/v3/clientportal/web_ai_widget/widget_configurations/ai_guidance": {
      "get": {
        "operationId": "getAiGuidanceMarkdown",
        "summary": "Get AI guidance markdown",
        "description": "Returns markdown guidance for the widget. **Not JSON:** body is raw markdown. `Content-Type: text/markdown; charset=utf-8`. **Business token** required. Optional query: `widget_uid`, `business_uid`.",
        "tags": ["Web AI Widget"],
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "name": "widget_uid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "business_uid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Markdown document",
            "content": {
              "text/markdown": {
                "schema": { "type": "string", "description": "Markdown document body" },
                "example": "# Business profile\n\n## Business contact information\n- **Phone:** +15551234567\n"
              }
            }
          },
          "422": {
            "description": "Semantic validation/business-rule failure (e.g. neither `widget_uid` nor `business_uid` was provided, or widget app is inactive)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "403": {
            "description": "Forbidden (business authentication required)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          },
          "404": {
            "description": "Widget configuration not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NestHttpException" }
              }
            }
          }
        }
      }
    },
    "/v3/clientportal/web_ai_widget/widget_configurations/{uid}": {
      "get": {
        "operationId": "getWidgetConfigurationByUid",
        "summary": "Retrieve a widget configuration",
        "description": "Returns one configuration by uid scoped to the authenticated business. **Business token** required.",
        "tags": ["Web AI Widget"],
