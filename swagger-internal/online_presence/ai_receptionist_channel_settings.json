{
  "openapi": "3.0.3",
  "info": {
    "title": "Online Presence - AI Receptionist Channel Settings",
    "description": "APIs for managing AI Receptionist settings per business channel under `/v3/online_presence/ai_receptionist_channel_settings`. These APIs are internal/private and are not part of the public API contract.",
    "version": "3.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "AI Receptionist Channel Settings",
      "description": "Channel-specific AI Receptionist settings for the authenticated business."
    }
  ],
  "servers": [
    {
      "url": "https://api.vcita.biz",
      "description": "API Gateway server"
    }
  ],
  "paths": {
    "/v3/online_presence/ai_receptionist_channel_settings/voices": {
      "get": {
        "summary": "List available AI Receptionist voices",
        "description": "Returns sanitized ElevenLabs voices that can be selected for AI Receptionist voice channels, including preview URLs when available. Available for **Staff tokens**.",
        "operationId": "listAiReceptionistChannelVoices",
        "tags": ["AI Receptionist Channel Settings"],
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": {
            "description": "Available AI Receptionist voices retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AiReceptionistVoicesPayload"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "voices": [
                      {
                        "voice_id": "21m00Tcm4TlvDq8ikWAM",
                        "name": "Rachel",
                        "description": "A calm and professional voice for business calls.",
                        "category": "premade",
                        "labels": {
                          "accent": "american",
                          "gender": "female"
                        },
                        "preview_url": "https://storage.googleapis.com/eleven-public-prod/premade/voices/preview.mp3"
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "503": { "$ref": "#/components/responses/ServiceUnavailable" }
        }
      }
    },
    "/v3/online_presence/ai_receptionist_channel_settings/voice_preview": {
      "post": {
        "summary": "Generate AI Receptionist voice preview",
        "description": "Generates playable MP3 preview audio for the provided unsaved welcome message and voice settings. The request does not create or update channel settings. Available for **Staff tokens**.",
        "operationId": "previewAiReceptionistChannelVoice",
        "tags": ["AI Receptionist Channel Settings"],
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PreviewAiReceptionistChannelVoiceRequest"
              },
              "example": {
                "settings": {
                  "welcome_message": "Hello, thanks for calling Smith Legal. How can I help today?",
                  "voice_id": "21m00Tcm4TlvDq8ikWAM",
                  "voice_name": "Rachel",
                  "voice_preview_url": "https://storage.googleapis.com/eleven-public-prod/premade/voices/preview.mp3",
                  "tts_stability": 0.75,
                  "tts_speed": 0.9,
                  "tts_style": 0.35
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Voice preview audio generated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AiReceptionistVoicePreviewPayload"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "voice_preview": {
                      "content_type": "audio/mpeg",
                      "audio_base64": "SUQzBAAAAAAAI1RTU0UAAAAPAAADTGF2ZjU4LjQ1LjEwMAAAAAAAAAAAAAAA"
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" },
          "503": { "$ref": "#/components/responses/ServiceUnavailable" }
        }
      }
    },
    "/v3/online_presence/ai_receptionist_channel_settings/{channel_uid}": {
      "get": {
        "summary": "Get AI Receptionist channel settings",
        "description": "Returns settings for one AI Receptionist channel for the authenticated business. If no row exists yet, the API returns default settings without creating a row. Available for **Staff tokens**.",
        "operationId": "getAiReceptionistChannelSetting",
        "tags": ["AI Receptionist Channel Settings"],
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "name": "channel_uid",
            "in": "path",
            "required": true,
            "description": "Stable channel identifier within the business (e.g., \"voicecalls:setting_123\").",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "AI Receptionist channel settings retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AiReceptionistChannelSettingPayload"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "ai_receptionist_channel_setting": {
                      "uid": "7b940b2b-6fd5-48b6-8bb6-2f6107ad8f64",
                      "business_uid": "d290f1ee26c54",
                      "channel_uid": "voicecalls:setting_123",
                      "settings": {
                        "welcome_message": "Hello, Welcome to Smith Legal, I'm a voice receptionist, any question or request I can help you with today?",
                        "voice_id": "21m00Tcm4TlvDq8ikWAM",
                        "voice_name": "Rachel",
                        "voice_preview_url": "https://storage.googleapis.com/eleven-public-prod/premade/voices/preview.mp3",
                        "tts_stability": 0.5,
                        "tts_speed": 1,
                        "tts_style": 0.3
                      },
                      "created_at": "2026-06-07T07:30:00Z",
                      "updated_at": "2026-06-07T07:35:00Z"
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      },
      "put": {
        "summary": "Update AI Receptionist channel settings",
        "description": "Updates settings for one AI Receptionist channel for the authenticated business. Available for **Staff tokens**.",
        "operationId": "updateAiReceptionistChannelSetting",
        "tags": ["AI Receptionist Channel Settings"],
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "name": "channel_uid",
            "in": "path",
            "required": true,
            "description": "Stable channel identifier within the business (e.g., \"voicecalls:setting_123\").",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAiReceptionistChannelSettingRequest"
              },
              "example": {
                "settings": {
                  "welcome_message": "Hello, thanks for calling Smith Legal. How can I help today?",
                  "voice_id": "21m00Tcm4TlvDq8ikWAM",
                  "voice_name": "Rachel",
                  "voice_preview_url": "https://storage.googleapis.com/eleven-public-prod/premade/voices/preview.mp3",
                  "tts_stability": 0.5,
                  "tts_speed": 1,
                  "tts_style": 0.3
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/AiReceptionistChannelSettingSuccess"
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      },
      "delete": {
        "summary": "Delete AI Receptionist channel settings",
        "description": "Deletes settings for one AI Receptionist channel for the authenticated business. Future reads fall back to product defaults. Available for **Staff tokens**.",
        "operationId": "deleteAiReceptionistChannelSetting",
        "tags": ["AI Receptionist Channel Settings"],
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "name": "channel_uid",
            "in": "path",
            "required": true,
            "description": "Stable channel identifier within the business (e.g., \"voicecalls:setting_123\").",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "AI Receptionist channel settings deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/DeleteAiReceptionistChannelSettingPayload"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "deleted": true
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v3/online_presence/ai_receptionist_channel_settings": {
      "post": {
        "summary": "Create AI Receptionist channel settings",
        "description": "Creates settings for one AI Receptionist channel for the authenticated business. Each business can have only one settings row per channel UID. Available for **Staff tokens**.",
        "operationId": "createAiReceptionistChannelSetting",
        "tags": ["AI Receptionist Channel Settings"],
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAiReceptionistChannelSettingRequest"
              },
              "example": {
                "channel_uid": "voicecalls:setting_123",
                "settings": {
                  "welcome_message": "Hello, thanks for calling Smith Legal. How can I help today?",
                  "voice_id": "21m00Tcm4TlvDq8ikWAM",
                  "voice_name": "Rachel",
                  "voice_preview_url": "https://storage.googleapis.com/eleven-public-prod/premade/voices/preview.mp3",
                  "tts_stability": 0.5,
                  "tts_speed": 1,
                  "tts_style": 0.3
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/AiReceptionistChannelSettingSuccess"
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AiReceptionistChannelSettingSettings": {
        "type": "object",
        "description": "Settings payload stored for a single AI Receptionist channel.",
        "properties": {
          "welcome_message": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000,
            "description": "Welcome message spoken when the AI receptionist answers this channel. Null or omitted values use the product default with the business name (e.g., \"Hello, Welcome to Smith Legal, I'm a voice receptionist, any question or request I can help you with today?\")."
          },
          "voice_id": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Identifier of the ElevenLabs voice used by this AI Receptionist channel. Null or omitted values use the product default voice (e.g., \"21m00Tcm4TlvDq8ikWAM\")."
          },
          "voice_name": {
            "type": "string",
            "nullable": true,
            "maxLength": 255,
            "description": "Display name of the selected ElevenLabs voice as shown in the settings UI. Runtime voice synthesis depends on `voice_id`; this field is a convenience snapshot for display (e.g., \"Rachel\")."
          },
          "voice_preview_url": {
            "type": "string",
            "nullable": true,
            "maxLength": 2048,
            "description": "Preview audio URL for the selected ElevenLabs voice, used by the settings UI to play a sample (e.g., \"https://storage.googleapis.com/eleven-public-prod/premade/voices/preview.mp3\")."
          },
          "tts_stability": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 1,
            "default": 0.5,
            "description": "ElevenLabs stability value for text-to-speech generation. Lower values sound more emotional and variable, while higher values sound more consistent. Null or omitted values use the product default (e.g., 0.5)."
          },
          "tts_speed": {
            "type": "number",
            "nullable": true,
            "minimum": 0.7,
            "maximum": 1.2,
            "default": 1,
            "description": "Speech speed multiplier for AI Receptionist text-to-speech generation. The settings UI uses a conservative call-quality range. Null or omitted values use the product default (e.g., 1.0)."
          },
          "tts_style": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 1,
            "default": 0,
            "description": "ElevenLabs style exaggeration value for text-to-speech generation. Higher values increase style intensity when supported by the selected voice. Null or omitted values use the product default (e.g., 0.0)."
          }
        }
      },
      "AiReceptionistVoice": {
        "type": "object",
        "description": "Sanitized voice option available for AI Receptionist channel text-to-speech.",
        "properties": {
          "voice_id": {
            "type": "string",
            "description": "Identifier of the ElevenLabs voice (e.g., \"21m00Tcm4TlvDq8ikWAM\")."
          },
          "name": {
            "type": "string",
            "description": "Human-readable voice name displayed in settings (e.g., \"Rachel\")."
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Voice description supplied by ElevenLabs when available (e.g., \"A calm and professional voice for business calls.\")."
          },
          "category": {
            "type": "string",
            "nullable": true,
            "description": "ElevenLabs voice category when available (e.g., \"premade\")."
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Voice labels supplied by ElevenLabs, such as accent, gender, or use case (e.g., { \"accent\": \"american\", \"gender\": \"female\" })."
          },
          "preview_url": {
            "type": "string",
            "nullable": true,
            "description": "URL of a sample audio preview for the voice when available (e.g., \"https://storage.googleapis.com/eleven-public-prod/premade/voices/preview.mp3\")."
          }
        },
        "required": ["voice_id", "name", "labels"]
      },
      "AiReceptionistVoicesPayload": {
        "type": "object",
        "properties": {
          "voices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiReceptionistVoice"
            },
            "description": "Available voices that can be selected for AI Receptionist channel settings."
          }
        },
        "required": ["voices"]
      },
      "AiReceptionistVoicePreview": {
        "type": "object",
        "description": "Base64-encoded MP3 audio preview generated from unsaved voice settings.",
        "properties": {
          "content_type": {
            "type": "string",
            "enum": ["audio/mpeg"],
            "description": "MIME type of the generated audio preview (e.g., \"audio/mpeg\")."
          },
          "audio_base64": {
            "type": "string",
            "description": "Base64-encoded MP3 audio bytes for the generated preview."
          }
        },
        "required": ["content_type", "audio_base64"]
      },
      "AiReceptionistVoicePreviewPayload": {
        "type": "object",
        "properties": {
          "voice_preview": {
            "$ref": "#/components/schemas/AiReceptionistVoicePreview"
          }
        },
        "required": ["voice_preview"]
      },
      "CreateAiReceptionistChannelSettingRequest": {
        "type": "object",
        "description": "Request body for creating AI Receptionist channel settings. The `channel_uid` must be unique per business.",
        "properties": {
          "channel_uid": {
            "type": "string",
            "description": "Stable channel identifier within the business (e.g., \"voicecalls:setting_123\")."
          },
          "settings": {
            "$ref": "#/components/schemas/AiReceptionistChannelSettingSettings"
          }
        },
        "required": ["channel_uid", "settings"]
      },
      "UpdateAiReceptionistChannelSettingRequest": {
        "type": "object",
        "description": "Request body for updating AI Receptionist channel settings. Provided settings are merged into the existing row.",
        "properties": {
          "settings": {
            "$ref": "#/components/schemas/AiReceptionistChannelSettingSettings"
          }
        },
        "required": ["settings"]
      },
      "PreviewAiReceptionistChannelVoiceRequest": {
        "type": "object",
        "description": "Request body for generating a temporary AI Receptionist voice preview from unsaved settings.",
        "properties": {
          "settings": {
            "$ref": "#/components/schemas/AiReceptionistChannelSettingSettings"
          }
        },
        "required": ["settings"]
      },
      "AiReceptionistChannelSettingPayload": {
        "type": "object",
        "properties": {
          "ai_receptionist_channel_setting": {
            "$ref": "https://vcita.github.io/developers-hub/entities/online_presence/AiReceptionistChannelSetting.json"
          }
        },
        "required": ["ai_receptionist_channel_setting"]
      },
      "DeleteAiReceptionistChannelSettingPayload": {
        "type": "object",
        "properties": {
          "deleted": {
            "type": "boolean",
            "description": "Whether the settings row was deleted."
          }
        },
        "required": ["deleted"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [false]
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "nullable": true
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              },
              "required": ["code", "message"]
            }
          }
        },
        "required": ["success", "errors"]
      }
    },
    "responses": {
      "AiReceptionistChannelSettingSuccess": {
        "description": "AI Receptionist channel settings saved successfully.",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                { "$ref": "https://vcita.github.io/developers-hub/entities/response.json" },
                {
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/AiReceptionistChannelSettingPayload"
                    }
                  }
                }
              ]
            },
            "example": {
              "success": true,
              "data": {
                "ai_receptionist_channel_setting": {
                  "uid": "7b940b2b-6fd5-48b6-8bb6-2f6107ad8f64",
                  "business_uid": "d290f1ee26c54",
                  "channel_uid": "voicecalls:setting_123",
                  "settings": {
                    "welcome_message": "Hello, thanks for calling Smith Legal. How can I help today?",
                    "voice_id": "21m00Tcm4TlvDq8ikWAM",
                    "voice_name": "Rachel",
                    "voice_preview_url": "https://storage.googleapis.com/eleven-public-prod/premade/voices/preview.mp3",
                    "tts_stability": 0.5,
                    "tts_speed": 1,
                    "tts_style": 0.3
                  },
                  "created_at": "2026-06-07T07:30:00Z",
                  "updated_at": "2026-06-07T07:35:00Z"
                }
              }
            }
          }
        }
      },
      "BadRequest": {
        "description": "Bad Request - malformed request.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "errors": [{ "code": "bad_request", "message": "Malformed request" }]
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - authentication is required.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "errors": [{ "code": "unauthorized", "message": "Authentication required" }]
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - business context is required or token is not allowed.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "errors": [{ "code": "forbidden", "message": "Business context required" }]
            }
          }
        }
      },
      "NotFound": {
        "description": "Not Found - settings row was not found for update or delete.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "errors": [
                {
                  "field": "channel_uid",
                  "code": "not_found",
                  "message": "AI receptionist channel settings not found"
                }
              ]
            }
          }
        }
      },
      "Conflict": {
        "description": "Conflict - settings already exist for this business and channel.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "errors": [
                {
                  "field": "channel_uid",
                  "code": "conflict",
                  "message": "AI receptionist channel settings already exist"
                }
              ]
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Unprocessable Entity - validation error.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "errors": [
                {
                  "field": "settings.welcome_message",
                  "code": "invalid",
                  "message": "Welcome message must be at most 1000 characters"
                }
              ]
            }
          }
        }
      },
      "ServiceUnavailable": {
        "description": "Service Unavailable - the upstream voice provider is unavailable or not configured.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "errors": [
                {
                  "code": "service_unavailable",
                  "message": "ElevenLabs API key is not configured"
                }
              ]
            }
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Provide a valid bearer token in the Authorization header. Example: `Authorization: Bearer {staff_token}`"
      }
    }
  }
}

